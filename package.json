{
  "name": "kaiten-mcp",
  "version": "0.1.1",
  "type": "module",
  "description": "MCP server for Kaiten — 63 tools across cards, comments, checklists, time-tracking, members, blockers, sprints, custom properties, external links, file uploads, location history, and global timesheet. Forked from iamtemazhe/mcp-kaiten with extensive Wave 1-5 fixes.",
  "author": "Amico1285 (https://github.com/Amico1285)",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/Amico1285/kaiten-mcp.git"
  },
  "homepage": "https://github.com/Amico1285/kaiten-mcp#readme",
  "bugs": {
    "url": "https://github.com/Amico1285/kaiten-mcp/issues"
  },
  "main": "build/index.js",
  "bin": {
    "kaiten-mcp": "build/index.js"
  },
  "files": [
    "build",
    "CHANGELOG.md"
  ],
  "scripts": {
    "build": "tsc && chmod 755 build/index.js",
    "start": "node build/index.js",
    "dev": "tsc --watch",
    "prepare": "npm run build",
    "inspector": "npx @modelcontextprotocol/inspector build/index.js",
    "test": "node --import tsx --test tests/unit/*.test.ts",
    "test:integration": "bash tests/integration/run-all.sh"
  },
  "keywords": [
    "mcp",
    "kaiten",
    "mcp-server",
    "project-management",
    "time-tracking",
    "members",
    "blockers",
    "sprints",
    "preflight",
    "llm",
    "cursor",
    "claude"
  ],
  "license": "MIT",
  "engines": {
    "node": ">=18"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.12.0",
    "zod": "^3.24.0"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "tsx": "^4.21.0",
    "typescript": "^5.7.0"
  }
}
