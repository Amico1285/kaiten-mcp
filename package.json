{
  "name": "mcp-kaiten",
  "version": "1.1.0",
  "type": "module",
  "description": "MCP server for Kaiten — cards, time-logs, boards, comments, users",
  "author": "Artem Zheleznov (https://github.com/iamtemazhe)",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/iamtemazhe/mcp-kaiten.git"
  },
  "homepage": "https://github.com/iamtemazhe/mcp-kaiten#readme",
  "bugs": {
    "url": "https://github.com/iamtemazhe/mcp-kaiten/issues"
  },
  "main": "build/index.js",
  "bin": {
    "mcp-kaiten": "build/index.js"
  },
  "files": [
    "build"
  ],
  "scripts": {
    "build": "tsc && chmod 755 build/index.js",
    "start": "node build/index.js",
    "dev": "tsc --watch",
    "prepare": "npm run build",
    "inspector": "npx @modelcontextprotocol/inspector build/index.js",
    "test": "node --import tsx --test tests/unit/*.test.ts",
    "test:integration": "bash tests/integration/run-all.sh"
  },
  "keywords": [
    "mcp",
    "kaiten",
    "mcp-server",
    "project-management",
    "time-tracking",
    "cursor",
    "claude"
  ],
  "license": "MIT",
  "engines": {
    "node": ">=18"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.12.0",
    "zod": "^3.24.0"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "tsx": "^4.21.0",
    "typescript": "^5.7.0"
  }
}
